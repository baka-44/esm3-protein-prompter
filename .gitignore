*.pt
*.pth
*.ckpt
*.onnx
models/

# ── Generated protein outputs (runtime artefacts, not source) ─────────────────
outputs/
results/
*.fasta
*.pdb

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
