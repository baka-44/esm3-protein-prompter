# ── Anthropic Claude API ──────────────────────────────────────────────────────
# Required for natural language → ESM3 prompt translation
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── ESM3 Backend ──────────────────────────────────────────────────────────────
# Option A: Forge API (recommended — access to larger, higher-quality models)
# Get a token at https://forge.evolutionaryscale.ai
FORGE_API_TOKEN=your_forge_token_here

# Option B: Local ESM3-open (1.4B, free, non-commercial)
# Set to "true" to force local model even if FORGE_API_TOKEN is set
# Strongly recommend running on a GPU (Colab Pro A100 for best performance)
USE_LOCAL_ESM3=false

# ── Optional Forge model override ─────────────────────────────────────────────
# Options: esm3-small-2024-08, esm3-medium-2024-08, esm3-large-2024-08
FORGE_MODEL=esm3-medium-2024-08
